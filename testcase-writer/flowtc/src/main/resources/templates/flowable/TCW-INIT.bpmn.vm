      <design:securitypolicy><![CDATA[TCW-SEC-001]]></design:securitypolicy>
    </extensionElements>
    <scriptTask id="ScriptTask_1" name="Init Test Case" scriptFormat="javascript" flowable:autoStoreVariables="false">
      <extensionElements>
        <flowable:in sourceExpression="#[[$]]#{root.getVariable('testCaseValues')}" target="testCaseValues"></flowable:in>
        <flowable:executionListener event="end" expression="#[[$]]#{root.setVariable('testCase', testCase)}"></flowable:executionListener>
        <design:stencilid><![CDATA[ScriptTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
      <script><![CDATA[
var testCase = {
    flowSteps: {},
    steps: [],
    pkgAndClassName: "${testCase.className}",
    metadata: {
        tags: [ 
#foreach( $tag in $testCase.tags )
    "$tag",
#end
        ],
        // TODO should come from a actionForm
        description: "${testCase.description}",
        transientId: "${testCase.name}"
    }
};
var jsonTestCase = flw.json.stringToJson(JSON.stringify(testCase)).get();

if (testCaseValues) {
  var flowSteps = flw.json.stringToJson(testCaseValues).path("flowSteps").get();
  if (!flowSteps.isMissingNode()) {
      jsonTestCase.withObjectProperty("flowSteps").setAll(flowSteps);
  }
}

execution.setVariable("testCase", jsonTestCase);
]]></script>
    </scriptTask>
