<project xmlns="http://maven.apache.org/POM/4.1.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.1.0 http://maven.apache.org/xsd/maven-4.1.0.xsd">
	<modelVersion>4.1.0</modelVersion>

	<parent/>

	<artifactId>testcase-writer-webapp</artifactId>
	<packaging>pom</packaging>

	<subprojects>
		<subproject>api-validators</subproject>
		<subproject>backend</subproject>
		<subproject>api-v0</subproject>
		<subproject>frontend</subproject>
		<subproject>war</subproject>
		<subproject>tests</subproject>
		<subproject>ide-runner</subproject>
	</subprojects>

	<properties>
		<apiPackageBase>ch.scaille.tcwriter.generated.api.controllers</apiPackageBase>
		<modelPackageBase>ch.scaille.tcwriter.generated.api.model</modelPackageBase>
		<configPackageBase>ch.scaille.tcwriter.generated.api.config</configPackageBase>
		<sonar.exclusions>**/generated-sources/**</sonar.exclusions>
	</properties>

	<dependencyManagement>
		<dependencies>
			<dependency>
				<groupId>ch.scaille.tcwriter</groupId>
				<artifactId>testcase-writer-webapp-api-validators</artifactId>
				<version>${revision}</version>
			</dependency>
			<dependency>
				<groupId>ch.scaille.tcwriter</groupId>
				<artifactId>testcase-writer-webapp-backend</artifactId>
				<version>${revision}</version>
			</dependency>
			<dependency>
				<groupId>ch.scaille.tcwriter</groupId>
				<artifactId>testcase-writer-webapp-api-v0-backend</artifactId>
				<version>${revision}</version>
			</dependency>
			<dependency>
				<groupId>ch.scaille.tcwriter</groupId>
				<artifactId>testcase-writer-webapp-api-v0-webapi</artifactId>
				<version>${revision}</version>
			</dependency>
			<dependency>
				<groupId>ch.scaille.tcwriter</groupId>
				<artifactId>testcase-writer-webapp-frontend</artifactId>
				<type>war</type>
				<version>${revision}</version>
			</dependency>
			<dependency>
				<groupId>ch.scaille.tcwriter</groupId>
				<artifactId>testcase-writer-webapp-war</artifactId>
				<type>war</type>
				<version>${revision}</version>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<profiles>
		<profile>
			<id>linux</id>
			<activation>
				<os>
					<family>unix</family>
				</os>
			</activation>
			<properties>
				<npm.cmd>npm</npm.cmd>
				<npx.cmd>npx</npx.cmd>
			</properties>
		</profile>
		<profile>
			<id>windows</id>
			<activation>
				<os>
					<family>windows</family>
				</os>
			</activation>
			<properties>
				<npm.cmd>npm.cmd</npm.cmd>
				<npx.cmd>npx.cmd</npx.cmd>
			</properties>
		</profile>
	</profiles>

	<build>
		<pluginManagement>
			<plugins>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-war-plugin</artifactId>
					<configuration>
						<failOnMissingWebXml>false</failOnMissingWebXml>
					</configuration>
				</plugin>
				<plugin>
					<groupId>org.openapitools</groupId>
					<artifactId>openapi-generator-maven-plugin</artifactId>
					<configuration>
						<ignoreFileOverride>
							${project.basedir}/.openapi-generator-ignore</ignoreFileOverride>
						<configOptions>
							<useSpringBoot4>true</useSpringBoot4>
							<useJackson3>true</useJackson3>
							<useJakartaEe>true</useJakartaEe>
							<useJspecify>true</useJspecify>
							<throwsException>true</throwsException>
							<useBeanValidation>true</useBeanValidation>
						</configOptions>
						<generatorName>spring</generatorName>
						<library>spring-boot</library>
					</configuration>
				</plugin>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-compiler-plugin</artifactId>
					<configuration>
						<annotationProcessorPaths>
							<path>
								<groupId>org.projectlombok</groupId>
								<artifactId>lombok</artifactId>
								<version>${lombok.version}</version>
							</path>
							<path>
								<groupId>org.mapstruct</groupId>
								<artifactId>mapstruct-processor</artifactId>
								<version>${mapstruct.version}</version>
							</path>
							<path>
								<groupId>org.springframework.boot</groupId>
								<artifactId>spring-boot-autoconfigure-processor</artifactId>
								<version>${springboot.version}</version>
							</path>
						</annotationProcessorPaths>
					</configuration>
				</plugin>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-dependency-plugin</artifactId>
					<executions>
						<execution>
							<id>copy</id>
							<phase>generate-resources</phase>
							<goals>
								<goal>copy</goal>
							</goals>
							<configuration>
								<overWriteIfNewer>true</overWriteIfNewer>
								<stripVersion>true</stripVersion>
								<stripClassifier>true</stripClassifier>
								<outputDirectory>
									${project.build.directory}/javatc-resources</outputDirectory>
								<artifactItems>
									<artifactItem>
										<groupId>ch.scaille.tcwriter</groupId>
										<artifactId>
											testcase-writer-javatc-client</artifactId>
										<version>${revision}</version>
										<type>jar</type>
										<classifier>fatjar</classifier>
									</artifactItem>
									<artifactItem>
										<groupId>org.aspectj</groupId>
										<artifactId>aspectjrt</artifactId>
										<version>${aspectj.version}</version>
										<type>jar</type>
									</artifactItem>
									<artifactItem>
										<groupId>org.aspectj</groupId>
										<artifactId>aspectjtools</artifactId>
										<version>${aspectj.version}</version>
										<type>jar</type>
									</artifactItem>
									<artifactItem>
										<groupId>org.junit.platform</groupId>
										<artifactId>
											junit-platform-console-standalone</artifactId>
										<version>
											${junit-platform-console-standalone.version}</version>
										<type>jar</type>
									</artifactItem>
								</artifactItems>
							</configuration>
						</execution>
					</executions>
				</plugin>
			</plugins>
		</pluginManagement>

	</build>
</project>
