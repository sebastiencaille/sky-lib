<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>ch.scaille.tcwriter</groupId>
		<artifactId>testcase-writer-webapp</artifactId>
		<version>${revision}</version>
	</parent>
	<!-- allows starting the war as a local application -->
	<packaging>war</packaging>
	<artifactId>testcase-writer-webapp-tests</artifactId>

	<dependencies>

		<dependency>
			<groupId>ch.scaille.tcwriter</groupId>
			<artifactId>testcase-writer-webapp-war</artifactId>
			<type>war</type>
			<scope>compile</scope>
		</dependency>

		<dependency>
			<groupId>ch.scaille</groupId>
			<artifactId>gui-pilot-selenium</artifactId>
		</dependency>

		<dependency>
			<groupId>ch.scaille</groupId>
			<artifactId>lib-testing-core</artifactId>
		</dependency>

		<dependency>
			<groupId>ch.scaille.tcwriter</groupId>
			<artifactId>testcase-writer-examples</artifactId>
		</dependency>

		<dependency>
			<groupId>org.springframework</groupId>
			<artifactId>spring-context</artifactId>
		</dependency>

		<dependency>
			<groupId>jakarta.annotation</groupId>
			<artifactId>jakarta.annotation-api</artifactId>
		</dependency>

	</dependencies>

	<build>
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-dependency-plugin</artifactId>
				<executions>
					<execution>
						<id>copy</id>
						<phase>generate-resources</phase>
						<goals>
							<goal>copy</goal>
						</goals>
						<configuration>
							<overWriteIfNewer>true</overWriteIfNewer>
							<stripVersion>true</stripVersion>
							<stripClassifier>true</stripClassifier>
							<outputDirectory>
								${project.build.directory}/example-resources</outputDirectory>
							<artifactItems>
								<artifactItem>
									<groupId>ch.scaille.tcwriter</groupId>
									<artifactId>testcase-writer-examples</artifactId>
									<version>${revision}</version>
									<type>jar</type>
								</artifactItem>
							</artifactItems>
							<!-- other configurations here -->
						</configuration>
					</execution>
				</executions>
			</plugin>
			<plugin>
				<artifactId>maven-war-plugin</artifactId>
				<configuration>
					<webResources>
						<resource>
							<directory>
								${project.build.directory}/example-resources</directory>
							<targetPath>example-resources</targetPath>
						</resource>
					</webResources>
				</configuration>
			</plugin>
		</plugins>
	</build>

	<profiles>

		<profile>
			<id>it</id>
			<activation>
				<property>
					<name>it</name>
					<value>!false</value>
				</property>
			</activation>
			<build>
				<plugins>
					<plugin>
						<groupId>org.codehaus.mojo</groupId>
						<artifactId>exec-maven-plugin</artifactId>
						<executions>
							<execution>
								<id>shutdown-server</id>
								<goals>
									<goal>exec</goal>
								</goals>
								<phase>post-integration-test</phase>
								<configuration>
									<skip>${skipTests}</skip>
									<executable>curl</executable>
									<arguments>
										<argument>-X</argument>
										<argument>POST</argument>
										<argument>
											http://localhost:9000/actuator/shutdown</argument>
									</arguments>
								</configuration>
							</execution>
						</executions>
					</plugin>
					<plugin>
						<groupId>org.springframework.boot</groupId>
						<artifactId>spring-boot-maven-plugin</artifactId>
						<executions>
							<execution>
								<id>repackage</id>
								<phase>none</phase>
							</execution>
							<execution>
								<id>pre-integration-test</id>
								<goals>
									<goal>start</goal>
								</goals>
								<configuration>
									<includes>
										<include>ch.scaille:lib-testing-core</include>
									</includes>
								</configuration>
							</execution>
							<execution>
								<id>post-integration-test</id>
								<goals>
									<goal>stop</goal>
								</goals>
							</execution>
						</executions>
						<configuration>
							<skip>${skipTests}</skip>
							<classesDirectory>${project.build.directory}/classes</classesDirectory>
							<mainClass>ch.scaille.testing.spring.TestWarLauncher</mainClass>
							<systemPropertyVariables>
								<mainClass>ch.scaille.tcwriter.server.Server</mainClass>
								<spring.datasource.url>jdbc:h2:mem:test</spring.datasource.url>
							</systemPropertyVariables>
							<arguments>
								<argument>--server.port=9000</argument>
							</arguments>

							<!-- needed for jmx -->
							<additionalClasspathElements>
								<directory>
									${project.build.directory}/${project.build.finalName}/</directory>
							</additionalClasspathElements>

						</configuration>
					</plugin>
					<plugin>
						<groupId>org.apache.maven.plugins</groupId>
						<artifactId>maven-failsafe-plugin</artifactId>
						<configuration>
							<systemPropertyVariables>
								<app.port>9000</app.port>
							</systemPropertyVariables>
						</configuration>
					</plugin>
				</plugins>
			</build>

		</profile>

	</profiles>

</project>
